.myText {
  background-color: #f4f4f4;
  padding: 20px;
}

.preview-content {
  margin-top: 20px;
}

.preview-section {
  background-color: #fff;
  border: 1px solid #ddd;
  border-radius: 5px;
  padding: 15px;
  margin-bottom: 20px;
}

h1, h2 {
  color: #333;
}

p {
  color: #666;
}

.error .MuiSelect-root {
  color: red;
}

.error .MuiInputLabel-root {
  color: red;
}

.date-picker-container.error .MuiFormControl-root {
  border: 1px solid red !important;
  border-radius: 4px; 
}

.beneficiary-photo-right {
  float: right; 
  margin-left: 20px; 
}


@media print {
  body * {
    visibility: hidden;
  }

  .preview-content,
  .preview-content * {
    visibility: visible;
  }

  .preview-content {
    position: absolute;
    left: 0;
    top: 0;
    padding: 20px;
  }

    .print-heading {
      display: block;
    }
    
        @page {
          margin: 0;
        }
    
        body {
          margin: 0;
        }

    
}


  