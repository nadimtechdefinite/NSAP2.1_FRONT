.disabled-cell-successOne {
  color: green; 
  pointer-events: none; 
} 
  .disabled-cell-success {
    color: transparent;
    pointer-events: none;
  }
  .disabled-cell-success:before {
    content: '************'; 
    color: green; 
  }
  .disabled-cell-failed{
    color: red; 
  }

  .verified-cell {
    color: green;
  }
  
  .failed-cell {
    color: red;
  }

  .blink {
    animation: blink-animation 1s infinite;
  }
  
  @keyframes blink-animation {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
  
  /* for contact no report*/
  @keyframes blink1 {
    0% { opacity: 1; }
    1% { opacity: 0; }
    100% { opacity: 1; }
  }
  
  .blinking {
    animation: blink1 3s infinite;
  }